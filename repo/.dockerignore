# TerraOps — Docker build context exclusions.
#
# Without this file the build context sent to the Docker daemon includes
# multi-GB build artefacts (target/, e2e/node_modules/) and macOS-compiled
# binaries that are incompatible with the linux/amd64 build image.

# Rust build artefacts — keep them off the context to prevent macOS/Linux
# binary incompatibilities and to avoid sending gigabytes on each rebuild.
target/
**/target/

# Frontend build outputs — regenerated by the frontend-build stage.
crates/frontend/dist/
crates/frontend/.trunk/

# Node / Playwright — macOS-compiled node_modules must never enter the
# Linux image context; the tests image bakes its own copy at build time.
e2e/node_modules/
e2e/playwright-report/
e2e/test-results/

# Coverage artefacts.
coverage/

# Git history — not needed inside any image.
.git/

# Runtime secrets — must never be committed or included in the context.
terraops-runtime/
.env
.env.*

# Temporary / local tooling dirs.
.tmp/

# Editor / OS noise.
.DS_Store
.idea/
.vscode/
*.swp
