# syntax=docker/dockerfile:1.7
#
# TerraOps test runner image.
#
# Scope (current delivered state — all four gates active):
#   * Gate 1 — `cargo test -p terraops-backend -p terraops-shared`
#     (real no-mock HTTP suite against real Postgres) driven by
#     `cargo-llvm-cov` with the line-coverage floor in `run_tests.sh`.
#   * Gate 2 — Frontend Verification Matrix (FVM): the
#     `wasm-bindgen-test` Node-mode suite for `terraops-frontend` plus
#     `scripts/frontend_verify.sh` evidence audit. This image therefore
#     includes the `wasm32-unknown-unknown` target, `wasm-bindgen-cli`
#     (matched to the crate's `wasm-bindgen` version), and a system
#     Node.js runtime.
#   * Gate 3 — `scripts/audit_endpoints.sh` (pure bash + awk).
#   * Flow gate — Playwright specs under `e2e/specs/` run against the
#     live `app` service on the compose network. The pinned Chromium
#     + Playwright browser payload and the pre-staged
#     `/opt/e2e/node_modules` are baked into this image so the flow
#     gate does not depend on a first-use network download.
#
# Design notes:
#   * Wasm source-based line coverage was evaluated and rejected as the
#     authoritative frontend proof on this toolchain (stable rust 1.88
#     `wasm32-unknown-unknown` sysroot ships no `profiler_builtins`; see
#     `docs/test-coverage.md §Why the frontend is not measured by wasm
#     source-based line coverage`). Gate 2 is therefore the FVM — a
#     requirement-row verification score, not a line-coverage
#     percentage. `grcov` is retained only as historical tooling; it is
#     not used by the current gate.

FROM rust:1.88-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    CARGO_TERM_COLOR=never \
    CARGO_NET_RETRY=10 \
    CARGO_HTTP_MULTIPLEXING=false \
    CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse \
    SQLX_OFFLINE=true \
    NODE_MAJOR=20 \
    CARGO_BUILD_JOBS=4

# System packages + Node.js LTS (for the wasm-bindgen-test-runner).
#
# `mold` fixes linker OOM-kills (`collect2: ld terminated with signal 9
# [Killed]`) that occur when `cargo llvm-cov` links the large
# instrumented backend binary. The fix is to make mold the *system* ld
# via update-alternatives (priority 100 beats binutils' default ~20).
#
# Why not RUSTFLAGS / config.toml?
#   `cargo llvm-cov` sets CARGO_ENCODED_RUSTFLAGS to inject
#   `-C instrument-coverage`, which takes precedence over config.toml
#   rustflags — so a rustflags-based approach is silently dropped.
#   Replacing the system ld is transparent to cargo-llvm-cov and also
#   to Gate 2a WASM builds: rustc uses the bundled `rust-lld` for
#   wasm32-unknown-unknown, never invoking the system ld at all.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      bash git curl ca-certificates jq gnupg xz-utils pkg-config libssl-dev mold \
 && mkdir -p /etc/apt/keyrings \
 && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
      | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
      > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/* \
 && update-alternatives --install /usr/bin/ld ld /usr/bin/mold 100 \
 && update-alternatives --set ld /usr/bin/mold

# wasm toolchain for Gate 2. `wasm-bindgen-cli` must match the
# `wasm-bindgen` version resolved in Cargo.lock exactly (the schema is
# not backward compatible between minor versions). 0.2.118 is the
# current transitive resolution via yew/gloo-net; bump in lockstep with
# `cargo update -p wasm-bindgen`.
RUN rustup target add wasm32-unknown-unknown \
 && cargo install --locked wasm-bindgen-cli --version 0.2.118

# Coverage tooling for Gate 1 (the only line-coverage gate in this
# repo):
#   * `cargo-llvm-cov` drives the native-Rust line-coverage gate
#     (`--fail-under-lines ${GATE1_LINE_FLOOR}` applied to
#     terraops-shared + terraops-backend).
#   * `grcov` is retained as historical tooling only; wasm source-line
#     coverage is not the authoritative frontend proof — Gate 2 is the
#     Frontend Verification Matrix instead. See `docs/test-coverage.md`.
# `llvm-tools-preview` ships the profdata/profcov binaries both tools
# rely on. Installed here so `run_tests.sh` can layer the Gate 1
# threshold on without needing on-demand `cargo install` at gate time.
RUN rustup component add llvm-tools-preview \
 && cargo install --locked cargo-llvm-cov --version 0.6.11 \
 && cargo install --locked grcov --version 0.8.24

# Playwright runtime (final-gate flow). Installs the runtime libs pinned
# Chromium needs at build time so the flow gate does not depend on a
# first-use network download at test time. `npm ci` + `npx playwright
# install chromium` are run against the pinned `e2e/package.json` so the
# browser payload lives in the image.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
      libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
      libgbm1 libpango-1.0-0 libcairo2 libasound2 \
 && rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN mkdir -p /opt/e2e ${PLAYWRIGHT_BROWSERS_PATH}
COPY e2e/package.json e2e/package-lock.json* /opt/e2e/
RUN cd /opt/e2e \
 && (npm ci --no-audit --no-fund 2>/dev/null || npm install --no-audit --no-fund) \
 && npx playwright install chromium

WORKDIR /workspace
